#include <iostream>
using namespace std;

// функции
void SayHello();
void Summa();
void Minus();
void Multiply();
void Divide();
bool Escape();

int main()
{
    setlocale(LC_ALL, "RU");

    // переменные и массивы
    char command;
    bool is_works = true;

    // приветствие
    cout << "Привет, пользователь!\n";
    cout << "Это Калькулятор версии 1.3\n";

    // собственно сам калькулятор
    while (is_works == true)
    {
        // комманды
        SayHello();

        // ввод
        cin >> command;

        // проверка комманды
        if (command == '+')
            Summa();
        else if (command == '-')
            Minus();
        else if (command == '*')
            Multiply();
        else if (command == '/')
            Divide();
        else if (command == 'e')
            is_works = Escape();
    }
    return 0;
}

void SayHello()
{
    cout << "Доступные комманды:\n";
    cout << "Сложение - '+'\n";
    cout << "Вычитание - '-'\n";
    cout << "Умножение - '*'\n";
    cout << "Деление - '/'\n";
    cout << "Выход - 'e'\n";
}
void Summa()
{
    float a;
    float b;
    
    cout << " \n";
    cout << "Сложение: a + b\n"; // формула

    // ввод чисел
    cout << "Введите а: ";
    cin >> a;
    cout << "Введите b: ";
    cin >> b;

    float answer = a + b;
    cout << a << " + " << b << " = " << answer << endl;
    cout << " \n";
}
void Minus()
{
    float a;
    float b;

    cout << " \n";
    cout << "Вычитание: a - b\n"; // формула

    // ввод чисел
    cout << "Введите а: ";
    cin >> a;
    cout << "Введите b: ";
    cin >> b;

    float answer = a - b;
    cout << a << " - " << b << " = " << answer << endl;
    cout << " \n";
}
void Multiply()
{
    float a;
    float b;

    cout << " \n";
    cout << "Умножение: a * b\n"; // формула

    // ввод чисел
    cout << "Введите а: ";
    cin >> a;
    cout << "Введите b: ";
    cin >> b;

    float answer = a * b;
    cout << a << " * " << b << " = " << answer << endl;
    cout << " \n";
}
void Divide()
{
    float a;
    float b;

    cout << " \n";
    cout << "Деление: a / b\n"; // формула

    // ввод чисел
    cout << "Введите а: ";
    cin >> a;
    cout << "Введите b: ";
    cin >> b;
    if (b != 0)
    {
        // вывод ответа
        float answer = a / b;
        cout << a << " / " << b << " = " << answer << endl;
    }
    else
        cout << "Ошибка: делить на ноль нельзя\n";
    cout << " \n";
}
bool Escape()
{
    cout << " \n";
    cout << "Выход из программы...\n";
    cout << "До встречи, пользователь!";
    cout << " \n";
    return false;
}
