int main()
{
	setlocale(LC_ALL, "RU");
	session_start = time(nullptr); // запуск таймера сессии

	// переменные
	char command;
	bool is_works = true;
	float massive[6] = { 0, 0, 0, 0, 0, 0 };

	// привет^^
	cout << "++======================================++\n";
	cout << "||   CalculatorCpp версии " << setw(10) << VERSION << "    ||\n";
	cout << "++======================================++\n";

	// основной цикл
	while (is_works)
	{
		SayHello();
		cin >> command;

		switch (command)
		{
		case '+': Summa(massive); break;
		case '-': Minus(massive); break;
		case '*': Multiply(massive); break;
		case '/': Divide(massive); break;
		case 'd':
			if (EnterDebugMode())
			{
				DebugMode(massive, stats);
			}
			break;
		case 'e': is_works = Escape(); break;
		case 'c': ClearCMD(); break;
		case 'p': Power(massive); break;
		case 's': SquareRoot(massive); break;
		case 'q': Quad(massive); break;
		default:
			cout << "\033[91mОшибка: неизвестная команда\033[0m\n"; stats[4]++;
		}
	}

	cout << "\nСпасибо за использование CalculatorCpp\n";
	return 0;
}

