//===================================
// MAIN
//===================================
int main()
{
	setlocale(LC_ALL, "RU");
	session_start = time(nullptr); // запуск таймера сессии

	// переменные
	string command;
	bool is_works = true;
	float massive[6] = { 0, 0, 0, 0, 0, 0 };

	// привет^^
	std::cout << "++======================================++\n";
	std::cout << "||   CalculatorCpp версии " << setw(10) << VERSION << "    ||\n";
	std::cout << "++======================================++\n";

	// основной цикл
	while (is_works)
	{
		SayHello();
		cin >> command;

		// основные операции
		if (command == "+" || command == "sum" || command == "1")
			Summa(massive);
		else if (command == "-" || command == "sub" || command == "2")
			Minus(massive);
		else if (command == "*" || command == "mult" || command == "3")
			Multiply(massive);
		else if (command == "/" || command == "div" || command == "4")
			Divide(massive);

		// утилиты, дебаг, выход
		else if (command == "d")
		{
			if (EnterDebugMode())
			{
				DebugMode(massive, stats);
			}
		}
		else if (command == "esc" || command == "0" || command == "e")
			is_works = Escape();
		else if (command == "clr" || command == "c" || command == "." || command == ",")
			ClearCMD();

		// продвинутые
		else if (command == "pow" || command == "5" || command == "p")
			Power(massive);
		else if (command == "sqrt" || command == "6" || command == "sr")
			SquareRoot(massive);
		else if (command == "quad" || command == "7" || command == "q")
			Quad(massive);
		else if (command == "pyth" || command == "8" || command == "pt")
			PythagoreanTheorem(massive);

		// исключения
		else
		{
			cout << "\033[91mОшибка: неизвестная команда\033[0m\n"; 
			stats[ERR]++;
		}
	}

	cout << "\nСпасибо за использование CalculatorCpp\n";
	return 0;
}

