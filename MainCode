/*
    Calculator v1.4.3
    Список изменений:
    1) замена всех переменных типа float на 1 большой массив данных
    2) комманда дебага: 'm' - показывает значения элементов массива
    Список правок:
    1) улучшена команда дебага: 'm'
    2) исправление грамматических ошибок
    3) замена *(mas+i) на mas[i]
    4) исправление 1-ой сука ошибки, снова
*/

#include <iostream>
using namespace std;

// функции
void SayHello();
void Summa(float* mas);
void Minus(float* mas);
void Multiply(float* mas);
void Divide(float* mas);
void MassivVal(float* mas);
void sep();
bool Escape();

int main()
{
    setlocale(LC_ALL, "RU");

    // переменные и массивы
    char command;
    bool is_works = true;
    float massiv[5] = { 0, 0, 0, 0, 0 };

    // приветствие
    cout << "Привет, пользователь!\n";
    cout << "Это Калькулятор версии 1.4.3\n";

    // собственно сам калькулятор
    while (is_works == true)
    {
        // комманды
        SayHello();

        // ввод
        cin >> command;

        // проверка комманды
        switch (command)
        {
        case '+': Summa(massiv); break;
        case '-': Minus(massiv); break;
        case '*': Multiply(massiv); break;
        case '/': Divide(massiv); break;
        case 'e': is_works = Escape(); break;
        case 'm': MassivVal(massiv); break;
        }
    }
    return 0;
}

void SayHello()
{
    cout << "Доступные комманды:\n";
    cout << "Сложение - '+'\n";
    cout << "Вычитание - '-'\n";
    cout << "Умножение - '*'\n";
    cout << "Деление - '/'\n";
    cout << "Выход - 'e'\n";
}
void Summa(float* mas)
{
    sep();
    cout << "Сложение: a + b\n"; // формула

    // ввод чисел
    cout << "Введите а: ";
    cin >> mas[0]; // первый элемент массива - a
    cout << "Введите b: ";
    cin >> mas[1]; // второй элемент массива - b

    mas[3] = mas[0] + mas[1]; // четвертый элемент массива - answer
    cout << mas[0] << " + " << mas[1] << " = " << mas[3] << endl;
    sep();
}
void Minus(float* mas) 
{
    sep();
    cout << "Вычитание: a - b\n"; // формула

    // ввод чисел
    cout << "Введите а: ";
    cin >> mas[0];
    cout << "Введите b: ";
    cin >> mas[1];

    mas[3] = mas[0] - mas[1];
    cout << mas[0] << " - " << mas[1] << " = " << mas[3] << endl;
    sep();
}
void Multiply(float* mas)
{
    sep();
    cout << "Умножение: a * b\n"; // формула

    // ввод чисел
    cout << "Введите а: ";
    cin >> mas[0];
    cout << "Введите b: ";
    cin >> mas[1];

    mas[3] = mas[0] * mas[1];
    cout << mas[0] << " * " << mas[1] << " = " << mas[3] << endl;
    sep();
}
void Divide(float* mas)
{
    sep();
    cout << "Деление: a / b\n"; // формула

    // ввод чисел
    cout << "Введите а: ";
    cin >> mas[0];
    cout << "Введите b: ";
    cin >> mas[1];
    if (mas[1] != 0)
    {
        // вывод ответа
        mas[3] = mas[0] / mas[1];
        cout << mas[0] << " / " << mas[1] << " = " << mas[3] << endl;
    }
    else
        cout << "Ошибка: делить на ноль нельзя\n";
    sep();
}
bool Escape()
{
    sep();
    cout << "Выход из программы...\n";
    cout << "До встречи, пользователь!";
    sep();
    return false;
}
void sep()
{
    cout << "\n";
    cout << "-------------------\n";
    cout << "\n";
}
void MassivVal(float* mas)
{
    sep();
    cout << "a - " << mas[0] << endl;
    cout << "b - " << mas[1] << endl;
    cout << "c - " << mas[2] << endl;
    cout << "Last answer - " << mas[3] << endl;
    cout << "Discr - " << mas[4] << endl;
    sep();
}
