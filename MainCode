#include <iostream>
#include <string>
#include <ctime>
#include <iomanip>
#include <limits>
#include <cstdlib>
using namespace std;

// ==================================
// КОНСТАНТЫ
// ==================================
const string VERSION = "1.5.4";
const string PASSWORD = "admin123";

//===================================
// ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ
//===================================
int stats[5];
time_t session_start;

//===================================
// ПРОТОТИПЫ ФУНКЦИЙ
//===================================
// основные
void SayHello();
void Summa(float* mas);
void Minus(float* mas);
void Multiply(float* mas);
void Divide(float* mas);
// Debug-режим
bool EnterDebugMode();
bool QuitDebugMode();
void DebugMode(float* mas, int* stat);
void ShowArray(float* mas);
void CalcStats(int* stats);

// Утилиты
void sep();
float GetFloat();
bool Escape();
void ClearCMD();

//===================================
// MAIN
//===================================
int main()
{
	setlocale(LC_ALL, "RU");
	session_start = time(nullptr); // запуск тайммера сессии

	// переменные
	char command;
	bool is_works = true;
	float massive[6] = { 0, 0, 0, 0, 0, 0 };

	// привет^^
	cout << "++======================================++\n";
	cout << "||   CalculatorCpp версии " << setw(10) << VERSION << "    ||\n";
	cout << "++======================================++\n";

	// основной цикл
	while (is_works)
	{
		SayHello();
		cin >> command;

		switch (command)
		{
		case '+': Summa(massive); break;
		case '-': Minus(massive); break;
		case '*': Multiply(massive); break;
		case '/': Divide(massive); break;
		case 'd':
			if (EnterDebugMode())
			{
				DebugMode(massive, stats);
			}
			break;
		case 'e': is_works = Escape(); break;
		case 'c': ClearCMD(); break;
		default:
			cout << "Ошибка: неизвестная команда\n"; stats[4]++;
		}
	}

	cout << "\nСпасибо за использование CalculatorCpp\n";
	return 0;
}

// ============================================================================
// ОСНОВНЫЕ ФУНКЦИИ КАЛЬКУЛЯТОРА
// ============================================================================
void SayHello()
{
	cout << "Доступные комманды:\n";
	cout << "'+' - Сложение\n";
	cout << "'-' - Вычитание\n";
	cout << "'*' - Умножение\n";
	cout << "'/' - Деление\n";
	cout << "'c' - Очистить экран\n";
	cout << "'e' - Выход\n";
	cout << "Введите команду: ";
}

void Summa(float* mas)
{
	sep();
	cout << "Сложение: a + b\n";

	cout << "Введите a: ";
	mas[0] = GetFloat();

	cout << "Введите b: ";
	mas[1] = GetFloat();

	mas[3] = mas[0] + mas[1];
	cout << "Результат: " << mas[0] << " + " << mas[1] << " = " << mas[3] << endl;
	stats[0]++;
	sep();
}

void Minus(float* mas)
{
	sep();
	cout << "Вычитание: a - b\n";

	cout << "Введите а: ";
	mas[0] = GetFloat();

	cout << "Введите b: ";
	mas[1] = GetFloat();

	mas[3] = mas[0] - mas[1];
	cout << "Результат: " << mas[0] << " - " << mas[1] << " = " << mas[3] << endl;

	stats[1]++;
	sep();
}

void Multiply(float* mas)
{
	sep();
	cout << "Умножение: a * b\n";

	cout << "Введите а: ";
	mas[0] = GetFloat();

	cout << "Введите b: ";
	mas[1] = GetFloat();

	mas[3] = mas[0] * mas[1];
	cout << "Результат: " << mas[0] << " * " << mas[1] << " = " << mas[3] << endl;

	stats[2]++;
	sep();
}

void Divide(float* mas)
{
	sep();
	cout << "Деление: a / b\n";

	cout << "Введите а: ";
	mas[0] = GetFloat();

	cout << "Введите b: ";
	mas[1] = GetFloat();

	if (mas[1] != 0)
	{
		mas[3] = mas[0] / mas[1];
		cout << "Результат: " << mas[0] << " / " << mas[1] << " = " << mas[3] << endl;
		stats[3]++;
	}
	else
	{
		cout << "Ошибка: делить на ноль нельзя!\n";
		stats[4]++;
	}
	sep();
}

// ============================================================================
// УТИЛИТЫ
// ============================================================================
void sep()
{
	cout << "\n-------------------\n\n";
}

float GetFloat()
{
	float val;

	while (true)
	{
		cin >> val;

		if (cin.fail())
		{
			cout << "Ошибка: введите число\n";

			cin.clear();
			cin.ignore(numeric_limits<streamsize>::max(), '\n');
			cout << "Попробуйте снова: ";
			continue;
		}
		cin.ignore(numeric_limits<streamsize>::max(), '\n');
		return val;
	}
}

bool Escape()
{
	sep();
	cout << "Выход из программы...\n";
	cout << "До встречи, пользователь!\n";
	sep();
	return false;
}

void ClearCMD()
{
#ifdef _WIN32
	system("cls");
#else
	system("clear");
#endif
}
// ============================================================================
// DEBUG MODE
// ============================================================================
bool EnterDebugMode()
{
	const int MAX_ATMP = 3;
	int attemps = 0;
	string input;

	sep();
	cout << "ВХОД В DEBUG MODE\n";
	while (attemps < MAX_ATMP)
	{
		cout << "Введите пароль (попытка " << (attemps + 1) << " из " << MAX_ATMP << "): ";
		cin >> input;

		if (input == PASSWORD)
		{
			cout << "Доступ разрешён!\n";
			return true;
		}
		else
		{
			cout << "Неверный пароль!\n";
			attemps++;
		}
	}

	cout << " Превышено количество попыток. Доступ заблокирован\n";
	stats[4]++;
	sep();
	return false;
}
void DebugMode(float* mas, int* stat)
{
	bool inDebug = true;
	char debugCMD;

	while (inDebug)
	{
		sep();
		cout << "DEBUG MODE MENU";
		cout << "\n[1] Просмотр массива\n";
		cout << "[2] Статистика вычислений\n";
		cout << "[3] Общая статистика (in progress)\n";
		cout << "[4] История вычислений (in progress)\n";
		cout << "[0] Выход из debug mode\n";
		cout << "Введите команду: ";
		cin >> debugCMD;

		switch (debugCMD)
		{
		case '0': inDebug = QuitDebugMode(); break;
		case '1': ShowArray(mas); break;
		case '2': CalcStats(stat); break;
		}
	}
}
bool QuitDebugMode()
{
	cout << "\n=======================\n";
	cout << "ВЫ ВЫШЛИ ИЗ DEBUG MODE";
	cout << "\n=======================\n\n";
	return false;
}
void ShowArray(float* mas)
{
	cout << "\n=ShowArray\n";

	cout << "a: " << mas[0] << endl;
	cout << "b: " << mas[1] << endl;
	cout << "c: " << mas[2] << endl;
	cout << "Last Answer: " << mas[3] << endl;
	cout << "Last second Answer: " << mas[4] << endl;
	cout << "Discr: " << mas[5] << endl;

}
void CalcStats(int* stats)
{
	cout << "\n=CalcStats\n";

	cout << "All operations: " << stats[0] + stats[1] + stats[2] + stats[3] << endl;
	cout << "Addition: " << stats[0] << endl;
	cout << "Substraction: " << stats[1] << endl;
	cout << "Multiplication: " << stats[2] << endl;
	cout << "Division: " << stats[3] << endl;
}
