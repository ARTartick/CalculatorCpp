void ShowHistory()
{
	cout << "\n=ShowHistory\n";

	if (history.empty())
	{
		cout << "\033[91mИстория операций пока что пуста...\033[0m" << endl;
	}
	int num = 1;
	for (auto it = history.rbegin(); it != history.rend(); ++it, ++num)
	{
		cout << "[" << num << "] " << *it << endl;
	}
}
