//===================================
int stats[9]; // 0 - add, 1 - min, 2 - mult, 3 - div, 4 - err, 5 - pow, 6 - sqrt, 7 - quad, 8 - PyTh
time_t session_start;
vector<string> history;

// Перечисление
enum MassiveNumbers
{
	A, B, C, ANS, X2, DISCR
};
enum StatNumbers
{
	ADD, MIN, MULT, DIV, ERR, POW, SQRT, QUAD, PYTH
};

//===================================
// ПРОТОТИПЫ ФУНКЦИЙ
//===================================
// основные
void SayHello();
void Summa(float* mas);
void Minus(float* mas);
void Multiply(float* mas);
void Divide(float* mas);
void Power(float* mas);
void SquareRoot(float* mas);
float Discr(float* mas);
void Quad(float* mas);
void PythagoreanTheorem(float* mas);
// Debug-режим
bool EnterDebugMode();
bool QuitDebugMode();
