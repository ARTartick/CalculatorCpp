void SayHello()
{
	cout << "Доступные комманды:\n";
	cout << "'+' - Сложение\n";
	cout << "'-' - Вычитание\n";
	cout << "'*' - Умножение\n";
	cout << "'/' - Деление\n";
	cout << "'p' - Возведение в степень\n";
	cout << "'c' - Очистить экран\n";
	cout << "'e' - Выход\n";
	cout << "Введите команду: ";
}

void Summa(float* mas)
{
	sep();
	cout << "Сложение: a + b\n";

	cout << "Введите a: ";
	mas[A] = GetFloat();

	cout << "Введите b: ";
	mas[B] = GetFloat();

	mas[ANS] = mas[A] + mas[B];
	cout << "Результат: " << mas[A] << " + " << mas[B] << " = " << mas[ANS] << endl;

	stats[0]++;
	AddHistory(FormatFloat(mas[A]) + " + " + FormatFloat(mas[B]) + " = " + FormatFloat(mas[ANS]));
	sep();
}

void Minus(float* mas)
{
	sep();
	cout << "Вычитание: a - b\n";

	cout << "Введите а: ";
	mas[A] = GetFloat();

	cout << "Введите b: ";
	mas[B] = GetFloat();

	mas[ANS] = mas[A] - mas[B];
	cout << "Результат: " << mas[A] << " - " << mas[B] << " = " << mas[ANS] << endl;

	stats[1]++;
	AddHistory(FormatFloat(mas[A]) + " - " + FormatFloat(mas[B]) + " = " + FormatFloat(mas[3]));
	sep();
}

void Multiply(float* mas)
{
	sep();
	cout << "Умножение: a * b\n";

	cout << "Введите а: ";
	mas[A] = GetFloat();

	cout << "Введите b: ";
	mas[B] = GetFloat();

	mas[ANS] = mas[A] * mas[B];
	cout << "Результат: " << mas[A] << " * " << mas[B] << " = " << mas[ANS] << endl;

	stats[2]++;
	AddHistory(FormatFloat(mas[A]) + " * " + FormatFloat(mas[B]) + " = " + FormatFloat(mas[ANS]));
	sep();
}

void Divide(float* mas)
{
	sep();
	cout << "Деление: a / b\n";

	cout << "Введите а: ";
	mas[A] = GetFloat();

	cout << "Введите b: ";
	mas[B] = GetFloat();

	if (mas[B] != 0)
	{
		mas[ANS] = mas[A] / mas[B];
		cout << "Результат: " << mas[A] << " / " << mas[B] << " = " << mas[ANS] << endl;
		stats[3]++;
		AddHistory(FormatFloat(mas[A]) + " / " + FormatFloat(mas[B]) + " = " + FormatFloat(mas[ANS]));
	}
	else
	{
		cout << "\033[91mОшибка: делить на ноль нельзя!\033[0m\n";
		stats[4]++;
		AddHistory(FormatFloat(mas[A]) + " / " + FormatFloat(mas[B]) + " = " + "ERROR");
	}
	sep();
}

void Power(float* mas)
{
	sep();
	cout << "Возведение в степень: a^^b\n";

	cout << "Введите а: ";
	mas[A] = GetFloat();

	cout << "Введите b: ";
	mas[B] = GetFloat();


	mas[ANS] = pow(mas[A], mas[B]);
	cout << "Результат: " << mas[A] << "^^" << mas[B] << " = " << mas[ANS] << endl;

	stats[5]++;
	AddHistory(FormatFloat(mas[A]) + "^^" + FormatFloat(mas[B]) + " = " + FormatFloat(mas[ANS]));
	sep();
}

// ============================================================================
// УТИЛИТЫ
// ============================================================================
void sep()
{
	cout << "\n-------------------\n\n";
}

float GetFloat()
{
	float val;

	while (true)
	{
		cin >> val;

		if (cin.fail())
		{
			cout << "Ошибка: введите число\n";

			cin.clear();
			cin.ignore(numeric_limits<streamsize>::max(), '\n');
			cout << "Попробуйте снова: ";
			continue;
		}
		cin.ignore(numeric_limits<streamsize>::max(), '\n');
		return val;
	}
}

bool Escape()
{
	sep();
	cout << "Выход из программы...\n";
	cout << "До встречи, пользователь!\n";
	sep();
	return false;
}

void ClearCMD()
{
#ifdef _WIN32
	system("cls");
#else
	system("clear");
#endif
}

void AddHistory(string op) 
{
	history.push_back(op);
	if (history.size() > 10)
	{
		history.erase(history.begin());
	}
}

string FormatFloat(float val)
{
	stringstream ss;
	ss << fixed << setprecision(2) << val;  // 2 знака после запятой
	return ss.str();
}
