void SayHello()
{
	cout << "\nДоступные комманды:\n";
	cout << "Сложение:                  [sum]\n";
	cout << "Вычитание:                 [sub]\n";
	cout << "Умножение:                [mult]\n";
	cout << "Деление:                   [div]\n";
	cout << "Возведение в степень:     [sqrt]\n";
	cout << "Квадратный корень:         [pow]\n";
	cout << "Квадратное уравнение:     [quad]\n";
	cout << "Теорема Пифагора:         [pyth]\n";
	cout << "Очистить экран:            [clr]\n";
	cout << "Выход:                     [esc]\n";
	cout << "--------------------------------\n";
	cout << "Введите команду: ";
}

void Summa(float* mas)
{
	ClearCMD();
	sep();
	cout << "Сложение: a + b\n";

	cout << "Введите a: ";
	mas[A] = GetFloat();

	cout << "Введите b: ";
	mas[B] = GetFloat();

	mas[ANS] = mas[A] + mas[B];
	cout << "Результат: " << mas[A] << " + " << mas[B] << " = " << mas[ANS] << endl;

	stats[ADD]++;
	AddHistory(FormatFloat(mas[A]) + " + " + FormatFloat(mas[B]) + " = " + FormatFloat(mas[ANS]));
	sep();
}

void Minus(float* mas)
{
	ClearCMD();
	sep();
	cout << "Вычитание: a - b\n";

	cout << "Введите а: ";
	mas[A] = GetFloat();

	cout << "Введите b: ";
	mas[B] = GetFloat();

	mas[ANS] = mas[A] - mas[B];
	cout << "Результат: " << mas[A] << " - " << mas[B] << " = " << mas[ANS] << endl;

	stats[MIN]++;
	AddHistory(FormatFloat(mas[A]) + " - " + FormatFloat(mas[B]) + " = " + FormatFloat(mas[3]));
	sep();
}

void Multiply(float* mas)
{
	ClearCMD();
	sep();
	cout << "Умножение: a * b\n";

	cout << "Введите а: ";
	mas[A] = GetFloat();

	cout << "Введите b: ";
	mas[B] = GetFloat();

	mas[ANS] = mas[A] * mas[B];
	cout << "Результат: " << mas[A] << " * " << mas[B] << " = " << mas[ANS] << endl;

	stats[MULT]++;
	AddHistory(FormatFloat(mas[A]) + " * " + FormatFloat(mas[B]) + " = " + FormatFloat(mas[ANS]));
	sep();
}

void Divide(float* mas)
{
	ClearCMD();
	sep();
	cout << "Деление: a / b\n";

	cout << "Введите а: ";
	mas[A] = GetFloat();

	cout << "Введите b: ";
	mas[B] = GetFloat();

	if (mas[B] != 0)
	{
		mas[ANS] = mas[A] / mas[B];
		cout << "Результат: " << mas[A] << " / " << mas[B] << " = " << mas[ANS] << endl;
		stats[DIV]++;
		AddHistory(FormatFloat(mas[A]) + " / " + FormatFloat(mas[B]) + " = " + FormatFloat(mas[ANS]));
	}
	else
	{
		cout << "\033[91mОшибка: делить на ноль нельзя!\033[0m\n";
		stats[ERR]++;
		AddHistory(FormatFloat(mas[A]) + " / " + FormatFloat(mas[B]) + " = " + "ERROR");
	}
	sep();
}

void Power(float* mas)
{
	ClearCMD();
	sep();
	cout << "Возведение в степень: a^^b\n";

	cout << "Введите а: ";
	mas[A] = GetFloat();

	cout << "Введите b: ";
	mas[B] = GetFloat();


	mas[ANS] = pow(mas[A], mas[B]);
	cout << "Результат: " << mas[A] << "^^" << mas[B] << " = " << mas[ANS] << endl;

	stats[POW]++;
	AddHistory(FormatFloat(mas[A]) + "^^" + FormatFloat(mas[B]) + " = " + FormatFloat(mas[ANS]));
	sep();
}

void SquareRoot(float* mas)
{
	ClearCMD();
	sep();
	cout << "Квадратный корень: √a\n";

	cout << "Введите a: ";
	mas[A] = GetFloat();

	if (mas[A] < 0)
	{
		cout << "Результат: √" << mas[A] << " = " << abs(mas[A]) << "i" << endl;
		stats[SQRT]++;
		AddHistory("√" + FormatFloat(mas[A]) + " = " + FormatFloat(abs(mas[A])) + "i");
	}
	else
	{
		mas[ANS] = sqrt(mas[A]);
		cout << "Результат: √" << mas[A] << " = " << mas[ANS] << endl;

		stats[SQRT]++;
		AddHistory("√" + FormatFloat(mas[A]) + " = " + FormatFloat(mas[ANS]));
	}
	sep();
}

float Discr(float* masiv)
{
	AddHistory(FormatFloat(masiv[B]) + "^^2 - 4 * " + FormatFloat(masiv[A]) + " * " + FormatFloat(masiv[C]) + " = " + FormatFloat(masiv[DISCR]));
	return (pow(masiv[B], 2) - (4 * masiv[A] * masiv[C]));
}

void Quad(float* mas)
{
	ClearCMD();
	sep();
	cout << "Квадратное уравнение: ax^^2 + bx + c = 0\n";

	cout << "Введите a: ";
	mas[A] = GetFloat();
	cout << "Введите b: ";
	mas[B] = GetFloat();
	cout << "Введите c: ";
	mas[C] = GetFloat();

	mas[DISCR] = Discr(mas);
	cout << "Дисриминант равен " << mas[DISCR] << endl;

	if (mas[DISCR] == 0)
	{
		cout << "Следовательно уравнение имеет 1 действительный корень\n";

		mas[ANS] = (-1 * mas[B]) / (2 * mas[A]);
		cout << "(-1 * " << mas[B] << ") / (2 * " << mas[A] << ") = " << mas[ANS] << endl;
		cout << "x1 = " << mas[ANS] << endl;
		AddHistory("(-1 * " + FormatFloat(mas[B]) + ") / (2 * " + FormatFloat(mas[A]) + ") = " + FormatFloat(mas[ANS]));
		stats[QUAD]++;
		sep();
	}
	else if (mas[DISCR] > 0)
	{
		cout << "Следовательно уравнение имеет 2 действительных корня\n";

		mas[ANS] = ((-1 * mas[B]) + sqrt(mas[DISCR])) / (2 * mas[A]);
		cout << "(-1 * " << mas[B] << ") + √" << mas[DISCR] << " / (2 * " << mas[A] << ") = " << mas[ANS] << endl;
		mas[X2] = ((-1 * mas[B]) - sqrt(mas[DISCR])) / (2 * mas[A]);
		cout << "(-1 * " << mas[B] << ") - √" << mas[DISCR] << " / (2 * " << mas[A] << ") = " << mas[ANS] << endl;

		cout << "x1 = " << mas[ANS] << endl;
		cout << "x2 = " << mas[X2] << endl;

		AddHistory("(-1 * " + FormatFloat(mas[B]) + ") + √" + FormatFloat(mas[DISCR]) + " / (2 * " + FormatFloat(mas[A]) + ") = " + FormatFloat(mas[ANS]));
		AddHistory("(-1 * " + FormatFloat(mas[B]) + ") - √" + FormatFloat(mas[DISCR]) + " / (2 * " + FormatFloat(mas[A]) + ") = " + FormatFloat(mas[X2]));
		stats[QUAD]++;
		sep();
	}
	else
	{
		cout << "Следовательно уравнение не имеет действительных корней\n";

		AddHistory("Нет действительных корней в уравнении: " + FormatFloat(mas[A]) + "x^^ + " + FormatFloat(mas[B]) + "x + " + FormatFloat(mas[C]) + " = 0");
		stats[QUAD]++;
		sep();
	}
}
void PythagoreanTheorem(float* mas)
{
	ClearCMD();
	sep();
	char num;

	cout << "Теорема Пифагора: AB^^2 + BC^^2 = AC^^2\n";
	cout << "Катет - 1\n";
	cout << "Гипотенуза - 2\n";
	cout << "Выберете, что хотите найти: ";
	cin >> num;

	if (num == '1')
	{
		ClearCMD();
		sep();
		cout << "Теорема Пифагора: BC^^2 = AC^^2 - AB^^2\n";
		cout << "Выберете, что хотите найти: " << num << endl;

		cout << "Введите длину катета: ";
		cin >> mas[A];

		cout << "Введите длину гипотенузы: ";
		cin >> mas[C];

		mas[ANS] = (pow(mas[C], 2) - pow(mas[A], 2));

		cout << "BC^^2 = " << pow(mas[C], 2) << " - " << pow(mas[A], 2) << " = " << mas[ANS] << endl;
		cout << "BC = √" << mas[ANS] << " или же " << sqrt(mas[ANS]);

		stats[PYTH]++;
		AddHistory("BC = √" + FormatFloat(mas[ANS]) + " или же " + FormatFloat(sqrt(mas[ANS])));
	}
	else if (num == '2')
	{
		ClearCMD();
		sep();
		cout << "Теорема Пифагора: AB^^2 + BC^^2 = AC^^2\n";
		cout << "Выберете, что хотите найти: " << num << endl;

		cout << "Введите длину катета: ";
		cin >> mas[A];

		cout << "Введите длину второго катета: ";
		cin >> mas[B];

		mas[ANS] = pow(mas[A], 2) + pow(mas[B], 2);

		cout << "AC^^2 = " << pow(mas[A], 2) << " - " << pow(mas[B], 2) << " = " << mas[ANS] << endl;
		cout << "AC = √" << mas[ANS] << " или же " << sqrt(mas[ANS]);

		AddHistory("AC = √" + FormatFloat(mas[ANS]) + " или же " + FormatFloat(sqrt(mas[ANS])));
		stats[PYTH]++;
	}
	else
	{
		cout << "\033[91mОшибка: неправильный ввод!\033[0m\n";
		stats[ERR]++;
	}
}

// ============================================================================
// УТИЛИТЫ
// ============================================================================
void sep()
{
	cout << "\n------------------------------------------\n\n";
}

float GetFloat()
{
	float val;

	while (true)
	{
		cin >> val;

		if (cin.fail())
		{
			cout << "Ошибка: введите число\n";

			cin.clear();
			cin.ignore(numeric_limits<streamsize>::max(), '\n');
			cout << "Попробуйте снова: ";
			continue;
		}
		cin.ignore(numeric_limits<streamsize>::max(), '\n');
		return val;
	}
}

bool Escape()
{
	sep();
	cout << "Выход из программы...\n";
	cout << "До встречи, пользователь!\n";
	sep();
	return false;
}

void ClearCMD()
{
#ifdef _WIN32
	system("cls");
#else
	system("clear");
#endif
	cout << "++======================================++\n";
	cout << "||   CalculatorCpp версии " << setw(10) << VERSION << "    ||\n";
	cout << "++======================================++\n";
}

void AddHistory(string op) 
{
	history.push_back(op);
	if (history.size() > 10)
	{
		history.erase(history.begin());
	}
}

string FormatFloat(float val)
{
	stringstream ss;
	ss << fixed << setprecision(2) << val;  // 2 знака после запятой
	return ss.str();
}
