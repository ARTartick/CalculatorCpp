bool EnterDebugMode()
{
	const int MAX_ATMP = 3;
	int attemps = 0;
	string input;

	sep();
	cout << "ВХОД В DEBUG MODE\n";
	while (attemps < MAX_ATMP)
	{
		cout << "Введите пароль (попытка " << (attemps + 1) << " из " << MAX_ATMP << "): ";
		cin >> input;

		if (input == PASSWORD)
		{
			cout << "Доступ разрешён!\n";
			return true;
		}
		else
		{
			cout << "Неверный пароль!\n";
			attemps++;
		}
	}

	cout << "\033[91mПревышено количество попыток. Доступ заблокирован\033[0m\n";
	stats[4]++;
	sep();
	return false;
}
void DebugMode(float* mas, int* stat)
{
	bool inDebug = true;
	char debugCMD;

	while (inDebug)
	{
		sep();
		cout << "DEBUG MODE MENU";
		cout << "\n[1] Просмотр массива\n";
		cout << "[2] Статистика вычислений\n";
		cout << "[3] Общая статистика\n";
		cout << "[4] История вычислений\n";
		cout << "[0] Выход из debug mode\n";

		cout << "Введите команду: ";
		cin >> debugCMD;

		switch (debugCMD)
		{
		case '0': inDebug = QuitDebugMode(); break;
		case '1': ShowArray(mas); break;
		case '2': CalcStats(stat); break;
		case '3': GeneralStats(stat); break;
		case '4': ShowHistory(); break;
		default: cout << "\033[91mError: Incorrect cmd\033[0m\n"; stat[4]++;
		}
	}
}
bool QuitDebugMode()
{
	cout << "\n=======================\n";
